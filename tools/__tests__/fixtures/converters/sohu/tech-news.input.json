      "html": "<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <link rel=\"icon\" href=\"//statics.itc.cn/web/static/images/pic/sohu-logo/favicon.ico\" type=\"image/x-icon\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <meta name=\"renderer\" content=\"webkit\" />\n    <title>当面“踢馆”大众！李想“报仇”，6年不晚？_搜狐汽车_搜狐网</title>\n    <meta name=\"data-spm\" content=\"smpc\">\n    <meta name=\"referrer\" content=\"no-referrer-when-downgrade\">\n    <meta http-equiv=\"Cache-Control\" content=\"no-transform\" />\n    <meta http-equiv=\"Cache-Control\" content=\"no-siteapp\" />\n    <meta name=\"description\" content=\"李想“踢馆”上汽大众，扬言“L9领先两代”。\" />\n    <meta property=\"og:type\" content=\"news\"/>\n    <meta property=\"og:title\" content=\"当面“踢馆”大众！李想“报仇”，6年不晚？\"/>\n    <meta property=\"og:description\" content=\"李想“踢馆”上汽大众，扬言“L9领先两代”。\"/>\n    <meta property=\"og:image\" content=\"http://sohu-media.bjcnc.scs.sohucs.com/web/static/images/sohu_logo.png\"/>\n    <meta property=\"og:url\" content=\"www.sohu.com/a/1016393915_477212\"/>\n    <meta property=\"og:release_date\" content=\"2026-04-29 20:57:19\"/>\n    <meta itemprop=\"dateUpdate\" content=\"2026-04-29 20:57:19\" />\n    <meta itemprop=\"datePublished\" content=\"2026-04-29 20:57:19\" />\n    <link rel=\"stylesheet\" href=\"https://s.auto.itc.cn/model2023/static/resource/dist/assets/css/loginLogic.06726b9d.css\">\n    <link rel=\"stylesheet\" href=\"https://s.auto.itc.cn/model2023/static/resource/dist/assets/css/contentRightContent.aef97407.css\">\n    <link rel=\"stylesheet\" href=\"https://s.auto.itc.cn/model2023/static/resource/dist/assets/css/index.7d11be53.css\">\n    <script>\n      var __autoArticleConfig = {\n        news_id: \"1016393915\",\n        media_id: \"477212\",\n        media_name: \"雷达财经\",\n        title: \"当面“踢馆”大众！李想“报仇”，6年不晚？\",\n        channel_url:\"//auto.sohu.com\",\n        modelId:\"6744\",\n        pubDate:\"2026-04-29 20