# macOS
.DS_Store
.AppleDouble
.LSOverride

# Claude Code per-project settings (permissions, etc.)
.claude/

# Node / TypeScript
node_modules/
*.log
npm-debug.log*
.npm
*.tsbuildinfo
dist/

# Local state — never commit; maps to remote-specific state
.wiki-lark-map.json
.wiki-sources-index.json
.wiki-batch-state.json
.wiki-fetch-issues.md
.wiki-raindrop-cache.json
.wiki-mention-map.json
.wiki-r2.json
batch-*-candidates.json
.curation-staging/
.refine-prompts/
.curation-prompts/

# Backup files (any *.bak alongside an already-ignored state file)
*.bak

# Local archive of salvaged analytical content from discarded ingest
# entries. Untracked by convention — keep on disk for personal reference,
# don't pollute the repo.
Meta/_archive/

# Raw fetched content. Per-bookmark slug dirs under raw/raindrop/<host>/<slug>/
# are large (often 10-100MB after image downloads), regenerable from
# Raindrop bookmarks via `hirono raindrop fetch-all`, and contain
# personal-source content that doesn't belong in version control.
# `_index.json` is a generated sidecar; also derived state.
raw/
.fetch-all.log

# Per-host sweep snapshots written by the bulk-fetch monitor and
# health-check tooling. Audit artefacts, derived from raw/.
sweep-results/_health/

# Editor
.vscode/
.idea/
*.swp
*~

# lark-hirono intermediates
.lark-hirono-cache/

# Obsidian — per-machine pane layout churns on every focus change.
# Share plugin config (app.json, appearance.json, core-plugins.json), not workspace state.
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache

# Stray empty Obsidian vault accidentally created during onboarding.
# The real vault IS this repo — the nested wiki/ folder is a misclick artifact.
/wiki/
